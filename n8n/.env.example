# Set one channel: telegram or email
NOTIFICATION_CHANNEL=telegram

# Roadmap settings
# Use 3 for a default 3-month plan, or set any preferred month count.
PREFERRED_MONTHS=3

# Comma-separated selected courses. Supported: java dsa, python, flutter, sql
SELECTED_COURSES=java dsa,python,flutter,sql

# Optional: YYYY-MM-DD. If empty, plan starts from today.
STUDY_PLAN_START_DATE=

# Telegram setup
TELEGRAM_BOT_TOKEN=123456789:replace_with_real_bot_token
TELEGRAM_CHAT_ID=replace_with_your_chat_id

# Email setup
FROM_EMAIL=you@example.com
TO_EMAIL=you@example.com
